{
  "version": 2,
  "builds": [
    { "src": "api_server.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },

    { "src": "^/$", "dest": "/index.html" },

    { "src": "^/(docs|redoc|openapi\\.json|health)$", "dest": "api_server.py" },
    { "src": "^/chat$", "dest": "api_server.py" },
    { "src": "^/confirm$", "dest": "api_server.py" },
    { "src": "^/chat/stream$", "dest": "api_server.py" },
    { "src": "^/session/.*$", "dest": "api_server.py" },
    { "src": "/favicon.ico", "dest": "api_server.py" }
  ],
  "functions": {
    "api_server.py": {
      "includeFiles": "favicon.ico"
    }
  }
}
